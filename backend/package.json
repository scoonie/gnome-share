    "@types/node": "^25.5.0",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode-svg": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
