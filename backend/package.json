    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "body-parser": "^2.2.0",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.4",
