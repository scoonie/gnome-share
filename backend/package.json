{
  "name": "gnome-share-backend",
  "version": "1.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "prod": "prisma migrate deploy && prisma db seed && node dist/src/main",
    "format": "prettier --end-of-line=auto --write 'src/**/*.ts'",
    "test:unit": "node --test -r ts-node/register -r tsconfig-paths/register test/*.spec.ts",
    "test:system": "prisma migrate reset -f && prisma db seed && nest start & wait-on http://localhost:8080/api/configs && newman run ./test/newman-system-tests.json"
  },
  "prisma": {
    "seed": "ts-node prisma/seed/config.seed.ts"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "body-parser": "^2.2.0",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.4",
    "clamscan": "^2.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "content-disposition": "^1.1.0",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.20",
    "jmespath": "^0.16.0",
    "jose": "^6.2.3",
    "mime-types": "^3.0.2",
    "nanoid": "^5.1.9",
    "nodemailer": "^8.0.7",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma": "^7.8.0",
    "qrcode-svg": "^1.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "uuid": "^14.0.0",
    "yaml": "^2.8.4"
  },
  "overrides": {
    "path-to-regexp": ">=8.4.0",
    "picomatch": ">=4.0.4",
    "handlebars": ">=4.7.9",
    "node-forge": ">=1.4.0",
    "flatted": ">=3.4.2",
    "qs": ">=6.14.2",
    "hono": ">=4.12.8",
    "@hono/node-server": ">=1.19.14",
    "ajv": ">=8.18.0",
    "effect": ">=3.20.0",
    "underscore": ">=1.13.8",
    "lodash": ">=4.17.24",
    "defu": ">=6.1.5",
    "axios": ">=1.15.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/archiver": "^7.0.0",
    "@types/clamscan": "^2.4.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jmespath": "^0.15.2",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode-svg": "^1.1.5",
    "@types/uuid": "^11.0.0",
    "cross-env": "^10.1.0",
    "newman": "^6.2.2",
    "prettier": "^3.8.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.5"
  }
}
